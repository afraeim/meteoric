# Meteoric Environment Configuration
# Copy this file to .env and adjust values as needed.
#
#   cp .env.example .env

# ── Quote Display ────────────────────────────────────────────────────────────
# Controls how selected-text quotes are displayed in the AskBar and chat bubbles.

# Maximum number of lines shown in the quote preview.
VITE_QUOTE_MAX_DISPLAY_LINES=4

# Maximum total characters shown in the quote preview.
VITE_QUOTE_MAX_DISPLAY_CHARS=300

# Maximum length of selected context text included in the prompt.
VITE_QUOTE_MAX_CONTEXT_LENGTH=4096

# ── Provider Selection ───────────────────────────────────────────────────────
# Supported providers: gemini | perplexity | openai | anthropic | ollama
# Defaults to openai.
METEORIC_AI_PROVIDER=openai

# ── System Prompt ────────────────────────────────────────────────────────────
# Custom system prompt prepended to every conversation.
# If unset or empty, defaults to the built-in prompt in src-tauri/prompts/system_prompt.txt.
METEORIC_SYSTEM_PROMPT=

# ── OpenAI Configuration ─────────────────────────────────────────────────────
# Required when METEORIC_AI_PROVIDER=openai
OPENAI_API_KEY=
# Optional OpenAI-compatible API base URL.
# Defaults to https://api.openai.com/v1.
# If OPENAI_API_KEY starts with `sk-or-v1-`, defaults automatically to
# https://openrouter.ai/api/v1.
METEORIC_OPENAI_BASE_URL=
# Optional OpenRouter headers (only used when base URL points to openrouter.ai).
METEORIC_OPENROUTER_HTTP_REFERER=
METEORIC_OPENROUTER_X_TITLE=Meteroic
# Defaults to gpt-4.1-mini if unset.
METEORIC_OPENAI_MODEL=gpt-4.1-mini

# ── Anthropic Configuration ──────────────────────────────────────────────────
# Required when METEORIC_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Defaults to claude-3-7-sonnet-latest if unset.
METEORIC_ANTHROPIC_MODEL=claude-3-7-sonnet-latest

# ── Gemini Configuration ─────────────────────────────────────────────────────
# Required when METEORIC_AI_PROVIDER=gemini
GEMINI_API_KEY=
# Optional OpenAI-compatible Gemini base URL.
# Defaults to https://generativelanguage.googleapis.com/v1beta/openai
METEORIC_GEMINI_BASE_URL=
# Defaults to gemini-2.5-flash if unset.
METEORIC_GEMINI_MODEL=gemini-2.5-flash

# ── Perplexity Configuration ─────────────────────────────────────────────────
# Required when METEORIC_AI_PROVIDER=perplexity
PERPLEXITY_API_KEY=
# Optional Perplexity OpenAI-compatible base URL.
# Defaults to https://api.perplexity.ai
METEORIC_PERPLEXITY_BASE_URL=
# Defaults to sonar if unset.
METEORIC_PERPLEXITY_MODEL=sonar

# ── Model Configuration ──────────────────────────────────────────────────────
# Comma-separated list of Ollama models Meteoric supports.
# The first entry is the active model used for inference.
# Defaults to gemma4:e2b if unset.
METEORIC_SUPPORTED_AI_MODELS=gemma4:e2b,gemma4:e4b
